<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DiscoverAdsFilter" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.DiscoverAdsFilter.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.DiscoverAdsFilter</item>
    </style>
</resources>
